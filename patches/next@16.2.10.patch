diff --git a/dist/client/dev/debug-channel.js b/dist/client/dev/debug-channel.js
index b4f67e73025c9bdb2a25ba553cc7913f0f3dcde1..d0d2c464a823661bf2cb14df2f8531bd87ffc94b 100644
--- a/dist/client/dev/debug-channel.js
+++ b/dist/client/dev/debug-channel.js
@@ -59,7 +59,12 @@ function wasServedFromCache() {
     try {
         // There is exactly one PerformanceNavigationTiming entry per page load.
         const entry = performance.getEntriesByType('navigation')[0];
-        return entry?.transferSize === 0;
+        if (!entry) return false;
+        // Patched (vercel/next.js#94634, fixed upstream in 16.3): Firefox
+        // reports transferSize===0 for streamed documents, causing a false
+        // "served from cache" -> location.reload() loop on Suspense pages.
+        // Only treat real cache restores as cached.
+        return entry.type === 'back_forward' || (entry.responseStart === 0 && entry.responseEnd > 0);
     } catch  {
         return false;
     }
