# Goftino support-chat widget id (public — embedded in the client bundle).
NEXT_PUBLIC_GOFTINO_WIDGET_ID=your_goftino_widget_id

# Backend API base URL (server-only). When set, every repository binds to its
# HTTP adapter (lib/infrastructure/*/http-*.repository.ts) instead of the
# in-memory mocks. Contracts for the backend team: doc/<feature>/api.md.
# API_BASE_URL=https://api.nakhoda.example/v1
